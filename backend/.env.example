# =============================================================================
# Backend Environment Variables
# Copy to .env and fill in values. Never commit .env.
# =============================================================================

# --- Firebase Admin (required for auth + Firestore) ---
# Option A – Local: path to JSON file (e.g. hackamined-*-firebase-adminsdk-*.json)
GOOGLE_APPLICATION_CREDENTIALS=hackamined-42869-firebase-adminsdk-fbsvc-e638c0d19e.json

# Option B – Render: paste full JSON (entire service account file contents)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# --- LLM API (required for /api/analyze and /api/chat) ---
LLM_API_URL=https://gpt-4-api-free.vercel.app/api/chat
LLM_API_KEY=

# --- CORS (allowed frontend origins) ---
FRONTEND_URL=https://the-v-box.vercel.app
CORS_ORIGINS=https://the-v-box.vercel.app,http://localhost:5173
